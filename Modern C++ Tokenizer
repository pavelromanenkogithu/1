#pragma once

#include <string>
#include <sstream>
#include <vector>

class Tokenizer {
public:
    explicit Tokenizer(std::string input)
        : input_(std::move(input)), stream_(input_) {}

    std::string next(char delim) {
        std::string token;
        if (!std::getline(stream_, token, delim)) {
            return {};
        }
        return token;
    }

    std::vector<std::string> split(char delim) {
        std::vector<std::string> tokens;
        std::string token;

        std::stringstream ss(input_);
        while (std::getline(ss, token, delim)) {
            tokens.push_back(token);
        }

        return tokens;
    }

private:
    std::string input_;
    std::stringstream stream_;
};
